# Replace every secret before running the stack.
RAG_API_KEY=change-me
WEBUI_SECRET_KEY=change-me

# Optional service endpoints and model settings.
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=wikijs_docs_hybrid
WIKI_BASE_URL=http://localhost:3000
LLM_URL=http://127.0.0.1:8001/v1
LLM_MODEL=Qwen/Qwen3-8B-AWQ
EMBEDDING_MODEL=ai-forever/FRIDA

# Hybrid retrieval returns this candidate pool to the cross-encoder. The
# reranker runs inside the RAG API process and may use CPU or CUDA.
RERANK_ENABLED=true
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANKER_DEVICE=auto
RERANK_CANDIDATES=40
RERANK_MAX_LENGTH=768
RERANK_BATCH_SIZE=4
RERANK_FAIL_OPEN=true
MAX_CHUNKS_PER_SECTION=2
